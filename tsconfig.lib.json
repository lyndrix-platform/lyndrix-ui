{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "declaration": true,
    "declarationDir": "./dist/types",
    "emitDeclarationOnly": true,
    "rootDir": "./src",
    "types": ["vite/client"]
  },
  "include": ["src/index.ts", "src/components/**/*.tsx", "src/pages/settings/shared.tsx", "src/lib/types.ts", "src/lib/api.ts", "src/lib/auth.ts", "src/lib/icons.ts", "src/lib/toast.ts", "src/lib/sharedUi.ts", "src/lib/useGreeting.ts"]
}
