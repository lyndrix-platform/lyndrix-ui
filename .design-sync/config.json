{
  "projectId": "1b13f728-e25f-49ac-9a12-dc091a059fd9",
  "pkg": "lyndrix-ui",
  "globalName": "LyndrixUI",
  "shape": "package",
  "buildCmd": "npm run build:lib",
  "srcDir": "src",
  "cssEntry": "dist/lyndrix.css",
  "runtimeFontPrefixes": ["Inter"],
  "extraEntries": ["./src/design-sync-providers.ts"],
  "provider": {
    "component": "QueryClientProvider",
    "props": { "client": { "$ref": "queryClient" } },
    "inner": { "component": "MemoryRouter" }
  },
  "overrides": {
    "AppShell": { "cardMode": "column" },
    "FeatureCard": { "cardMode": "column" }
  },
  "readmeHeader": ".design-sync/conventions.md",
  "guidelinesGlob": [".design-sync/guidelines/**/*.md"]
}
